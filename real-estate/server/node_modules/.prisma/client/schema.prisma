datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())

  @@map("admins")
}

model Customer {
  id         Int         @id @default(autoincrement())
  fullName   String
  mobile     String
  email      String      @unique
  password   String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  enquiries  Enquiry[]
  wishlists  Wishlist[]
  siteVisits SiteVisit[]

  @@map("customers")
}

model Property {
  id          Int             @id @default(autoincrement())
  title       String
  description String?
  type        String // Plot, Villa, House, Land, Apartment
  status      String          @default("Available")
  location    String
  price       String
  size        String
  beds        Int             @default(0)
  baths       Int             @default(0)
  mapLink     String? // Google Maps Link
  createdAt   DateTime        @default(now())
  images      PropertyImage[]
  enquiries   Enquiry[]
  wishlists   Wishlist[]
  siteVisits  SiteVisit[]

  @@map("properties")
}

model PropertyImage {
  id         Int      @id @default(autoincrement())
  propertyId Int
  url        String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("property_images")
}

model Enquiry {
  id           Int       @id @default(autoincrement())
  customerId   Int?
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  name         String // Guest or customer name fallback
  email        String
  phone        String
  propertyId   Int?
  property     Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  propertyName String // Mapped property name
  notes        String?
  status       String    @default("New") // New, Contacted, Follow-up, Closed
  createdAt    DateTime  @default(now())

  @@map("enquiries")
}

model FollowUp {
  id        Int      @id @default(autoincrement())
  client    String
  type      String
  date      String
  property  String
  notes     String?
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("followups")
}

model SiteVisit {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  visitDate  String
  status     String   @default("Pending") // Pending, Confirmed, Cancelled, Completed
  createdAt  DateTime @default(now())

  @@map("site_visits")
}

model Wishlist {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  propertyId Int
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([customerId, propertyId])
  @@map("wishlist")
}
